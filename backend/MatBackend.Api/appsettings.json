{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MatBackend.Infrastructure.Services.TrainingService": "Information",
      "MatBackend.Infrastructure.Repositories.FileSkillStateRepository": "Warning"
    }
  },
  "Scoring": {
    "VerboseLogging": false,
    "MaxEvidence": 30.0,
    "MinAttempts": 3,
    "DifficultyWeightMin": 0.5,
    "DifficultyWeightMax": 1.0,
    "MaxDifficulty": 5.0,
    "PrimarySkillWeightFraction": 0.70
  },
  "AllowedHosts": "*",
  "DataSettings": {
    "DataRoot": "../data",
    "TasksRoot": "../../tasks",
    "TaskTypesRoot": "../../curriculum/task-types"
  },
  "OpenAI": {
    "ApiKey": "",
    "ModelId": "gpt-4",
    "UseAzure": false,
    "AzureEndpoint": "",
    "MaxTokens": 50000,
    "Temperature": 0.7
  },
  "Gemini": {
    "ApiKey": "",
    "ModelId": "gemini-3-pro-image-preview",
    "ImageGenerationEnabled": false
  },
  "Generation": {
    "FastMode": true,
    "BatchSize": 5,
    "MaxParallelBatches": 3
  },
  "ScalewayTem": {
    "SecretKey": "",
    "ProjectId": "",
    "Region": "fr-par",
    "SenderEmail": "noreply@mattutor.dk",
    "SenderName": "Matematik Tutor"
  },
  "Auth": {
    "FrontendUrl": "http://localhost:5173"
  },
  "Keycloak": {
    "Authority": "https://auth.mattutor.dk/realms/mat-tutor",
    "Audience": "mat-backend"
  },
  "StudentStorage": {
    "Provider": "File",
    "S3": {
      "BucketName": "mat-student-data",
      "Region": "fr-par",
      "ServiceUrl": "https://s3.fr-par.scw.cloud",
      "AccessKey": "",
      "SecretKey": ""
    }
  }
}
