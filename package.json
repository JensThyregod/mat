{
  "name": "mat-tutor-monorepo",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "zitadel:up": "docker compose up -d",
    "zitadel:down": "docker compose down",
    "zitadel:logs": "docker compose logs -f zitadel-api",
    "zitadel:restart": "docker compose restart zitadel-api zitadel-login",
    "zitadel:apply": "cd infra/local && terraform init -input=false && terraform apply -auto-approve",
    "test": "npm run test --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  }
}
